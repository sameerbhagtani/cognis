{
    "name": "cognis",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.13.1",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "clean": "turbo clean",
        "postclean": "rimraf node_modules .turbo",
        "db:up": "docker compose up -d",
        "db:down": "docker compose down",
        "db:reset": "docker compose down -v && docker compose up -d",
        "db:generate": "turbo db:generate --filter=@cognis/database",
        "db:migrate": "turbo db:migrate --filter=@cognis/database",
        "db:push": "turbo db:push --filter=@cognis/database"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "prettier": "^3.9.5",
        "rimraf": "^6.1.3",
        "turbo": "^2.10.5",
        "typescript": "^7.0.2"
    }
}
